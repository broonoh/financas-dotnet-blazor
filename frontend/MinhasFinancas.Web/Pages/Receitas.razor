@page "/receitas"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MinhasFinancas.Web.Services
@using MinhasFinancas.Web.Models
@inject DashboardApiService ApiService
@inject IJSRuntime JS

<MudText Typo="Typo.h4" Class="mb-4">Receitas</MudText>

<MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary"
           Variant="Variant.Filled" OnClick="@(() => { _mostrarForm = !_mostrarForm; _editandoId = null; })" Class="mb-4">
    Nova Receita
</MudButton>
<MudButton StartIcon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Success"
           Variant="Variant.Outlined" OnClick="DownloadPdf" Disabled="_baixandoPdf" Class="mb-4 ml-2">
    @if (_baixandoPdf) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
    Exportar PDF
</MudButton>

@if (_mostrarForm && _editandoId == null)
{
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-3">Nova Receita</MudText>
        @FormContent(false)
    </MudPaper>
}

@if (_carregando)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_receitas?.Count > 0)
{
    <MudTable Items="_receitas" Hover="true" Striped="true" Dense="true" Breakpoint="Breakpoint.Sm" HorizontalScrollbar="true">
        <HeaderContent>
            <MudTh>Descrição</MudTh>
            <MudTh>Valor</MudTh>
            <MudTh>Data</MudTh>
            <MudTh>Categoria</MudTh>
            <MudTh>Recorrente</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            @if (_editandoId == context.Id)
            {
                <MudTd colspan="6">
                    <MudPaper Elevation="0" Class="pa-3">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Editando receita</MudText>
                        @FormContent(true)
                    </MudPaper>
                </MudTd>
            }
            else
            {
                <MudTd>@context.Descricao</MudTd>
                <MudTd>@context.Valor.ToString("C2", new System.Globalization.CultureInfo("pt-BR"))</MudTd>
                <MudTd>@context.DataRecebimento.ToString("dd/MM/yyyy")</MudTd>
                <MudTd>@context.Categoria</MudTd>
                <MudTd>@(context.Recorrente ? "Sim" : "Não")</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => IniciarEdicao(context))" Title="Editar" />
                    @if (_excluindoId == context.Id)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    }
                    else
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => Excluir(context.Id))" Title="Excluir" />
                    }
                </MudTd>
            }
        </RowTemplate>
    </MudTable>
}
else if (!_carregando)
{
    <MudAlert Severity="Severity.Info">Nenhuma receita cadastrada ainda.</MudAlert>
}

@code {
    private RenderFragment FormContent(bool editando) =>@<MudGrid>
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="_descricao" Label="Descrição" Variant="Variant.Outlined" FullWidth="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudTextField @bind-Value="_valorStr" Label="Valor (R$)" Variant="Variant.Outlined" FullWidth="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudDatePicker @bind-Date="_dataRecebimento" Label="Data de Recebimento"
                           Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" Editable="true" PickerVariant="PickerVariant.Dialog" />
        </MudItem>
        <MudItem xs="12" md="4">
            @if (_categorias?.Count > 0)
            {
                <MudSelect T="string" @bind-Value="_categoria" Label="Categoria" Variant="Variant.Outlined" FullWidth="true">
                    @foreach (var cat in _categorias)
                    {
                        <MudSelectItem Value="@cat.Nome">@cat.Nome</MudSelectItem>
                    }
                </MudSelect>
            }
            else
            {
                <MudTextField @bind-Value="_categoria" Label="Categoria" Variant="Variant.Outlined" FullWidth="true"
                              Placeholder="Nenhuma categoria. Cadastre em Categorias > Receita" />
            }
        </MudItem>
        @if (!editando)
        {
            <MudItem xs="12" md="2" Class="d-flex align-center">
                <MudCheckBox @bind-Value="_recorrente" Label="Recorrente" />
            </MudItem>
        }
        <MudItem xs="12">
            @if (!string.IsNullOrEmpty(_erro))
            {
                <MudAlert Severity="Severity.Error" Class="mb-2">@_erro</MudAlert>
            }
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       OnClick="@(editando ? Atualizar : Salvar)" Disabled="_salvando">
                @if (_salvando) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                @(editando ? "Atualizar" : "Salvar")
            </MudButton>
            <MudButton Class="ml-2" OnClick="Cancelar">Cancelar</MudButton>
        </MudItem>
    </MudGrid>;
}

@code {
    private List<ReceitaDto>? _receitas;
    private List<CategoriaDto>? _categorias;
    private bool _carregando = true;
    private bool _mostrarForm;
    private bool _salvando;
    private bool _baixandoPdf;
    private string _erro = string.Empty;
    private Guid? _excluindoId;
    private Guid? _editandoId;

    private string _descricao = string.Empty;
    private string _valorStr = string.Empty;
    private DateTime? _dataRecebimento;
    private string _categoria = string.Empty;
    private bool _recorrente;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(Carregar(), CarregarCategorias());
    }

    private async Task Carregar()
    {
        _carregando = true;
        _receitas = await ApiService.ListarReceitasAsync() ?? [];
        _carregando = false;
    }

    private async Task CarregarCategorias()
    {
        _categorias = await ApiService.ListarCategoriasReceitaAsync() ?? [];
        if (_categoria == string.Empty && _categorias.Count > 0)
            _categoria = _categorias[0].Nome;
    }

    private void IniciarEdicao(ReceitaDto receita)
    {
        _editandoId = receita.Id;
        _mostrarForm = false;
        _descricao = receita.Descricao;
        _valorStr = receita.Valor.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
        _dataRecebimento = receita.DataRecebimento.ToDateTime(TimeOnly.MinValue);
        _categoria = receita.Categoria;
        _recorrente = receita.Recorrente;
        _erro = string.Empty;
    }

    private void Cancelar()
    {
        _mostrarForm = false;
        _editandoId = null;
        _descricao = string.Empty;
        _valorStr = string.Empty;
        _dataRecebimento = null;
        _categoria = _categorias?.FirstOrDefault()?.Nome ?? string.Empty;
        _recorrente = false;
        _erro = string.Empty;
    }

    private bool ValidarForm()
    {
        if (string.IsNullOrWhiteSpace(_descricao) || string.IsNullOrWhiteSpace(_valorStr) || _dataRecebimento is null)
        {
            _erro = "Preencha todos os campos obrigatórios.";
            return false;
        }
        if (!decimal.TryParse(_valorStr.Replace(",", "."), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var v) || v <= 0)
        {
            _erro = "Valor inválido.";
            return false;
        }
        return true;
    }

    private async Task Salvar()
    {
        _erro = string.Empty;
        if (!ValidarForm()) return;

        decimal.TryParse(_valorStr.Replace(",", "."), System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var valor);

        _salvando = true;
        var payload = new
        {
            Descricao = _descricao,
            Valor = valor,
            DataRecebimento = DateOnly.FromDateTime(_dataRecebimento!.Value),
            Categoria = _categoria,
            Recorrente = _recorrente
        };

        var (sucesso, erro) = await ApiService.CriarReceitaAsync(payload);
        _salvando = false;

        if (sucesso)
        {
            Cancelar();
            await Carregar();
        }
        else
        {
            _erro = erro ?? "Erro ao salvar receita.";
        }
    }

    private async Task Atualizar()
    {
        _erro = string.Empty;
        if (!ValidarForm()) return;

        decimal.TryParse(_valorStr.Replace(",", "."), System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var valor);

        _salvando = true;
        var payload = new
        {
            Descricao = _descricao,
            Valor = valor,
            DataRecebimento = DateOnly.FromDateTime(_dataRecebimento!.Value),
            Categoria = _categoria
        };

        var (sucesso, erro) = await ApiService.AtualizarReceitaAsync(_editandoId!.Value, payload);
        _salvando = false;

        if (sucesso)
        {
            Cancelar();
            await Carregar();
        }
        else
        {
            _erro = erro ?? "Erro ao atualizar receita.";
        }
    }

    private async Task Excluir(Guid id)
    {
        _excluindoId = id;
        await ApiService.ExcluirReceitaAsync(id);
        _excluindoId = null;
        await Carregar();
    }

    private async Task DownloadPdf()
    {
        _baixandoPdf = true;
        var bytes = await ApiService.DownloadReceitasPdfAsync();
        _baixandoPdf = false;
        if (bytes is not null)
            await JS.InvokeVoidAsync("downloadFileFromBytes", "receitas.pdf", "application/pdf", Convert.ToBase64String(bytes));
    }
}
