@page "/receitas"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MinhasFinancas.Web.Services
@using MinhasFinancas.Web.Models
@inject DashboardApiService ApiService

<MudText Typo="Typo.h4" Class="mb-4">Receitas</MudText>

<MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary"
           Variant="Variant.Filled" OnClick="@(() => _mostrarForm = !_mostrarForm)" Class="mb-4">
    Nova Receita
</MudButton>

@if (_mostrarForm)
{
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-3">Nova Receita</MudText>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_descricao" Label="Descrição" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="_valorStr" Label="Valor (R$)" Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="_dataStr" Label="Data de Recebimento" InputType="InputType.Date"
                              Variant="Variant.Outlined" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="string" @bind-Value="_categoria" Label="Categoria" Variant="Variant.Outlined" FullWidth="true">
                    <MudSelectItem Value="@("Salario")">Salário</MudSelectItem>
                    <MudSelectItem Value="@("Freelancer")">Freelancer</MudSelectItem>
                    <MudSelectItem Value="@("Investimento")">Investimento</MudSelectItem>
                    <MudSelectItem Value="@("Presente")">Presente</MudSelectItem>
                    <MudSelectItem Value="@("Outros")">Outros</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-center">
                <MudCheckBox @bind-Value="_recorrente" Label="Recorrente" />
            </MudItem>
            <MudItem xs="12">
                @if (!string.IsNullOrEmpty(_erro))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-2">@_erro</MudAlert>
                }
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Salvar" Disabled="_salvando">
                    @if (_salvando) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Salvar
                </MudButton>
                <MudButton Class="ml-2" OnClick="@(() => _mostrarForm = false)">Cancelar</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

@if (_carregando)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_receitas?.Count > 0)
{
    <MudTable Items="_receitas" Hover="true" Striped="true" Dense="true">
        <HeaderContent>
            <MudTh>Descrição</MudTh>
            <MudTh>Valor</MudTh>
            <MudTh>Data</MudTh>
            <MudTh>Categoria</MudTh>
            <MudTh>Recorrente</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Descricao</MudTd>
            <MudTd>@context.Valor.ToString("C2", new System.Globalization.CultureInfo("pt-BR"))</MudTd>
            <MudTd>@context.DataRecebimento.ToString("dd/MM/yyyy")</MudTd>
            <MudTd>@context.Categoria</MudTd>
            <MudTd>@(context.Recorrente ? "Sim" : "Não")</MudTd>
            <MudTd>
                @if (_excluindoId == context.Id)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => Excluir(context.Id))" Title="Excluir" />
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}
else if (!_carregando)
{
    <MudAlert Severity="Severity.Info">Nenhuma receita cadastrada ainda.</MudAlert>
}

@code {
    private List<ReceitaDto>? _receitas;
    private bool _carregando = true;
    private bool _mostrarForm;
    private bool _salvando;
    private string _erro = string.Empty;
    private Guid? _excluindoId;

    private string _descricao = string.Empty;
    private string _valorStr = string.Empty;
    private string _dataStr = string.Empty;
    private string _categoria = "Salario";
    private bool _recorrente;

    protected override async Task OnInitializedAsync()
    {
        await Carregar();
    }

    private async Task Carregar()
    {
        _carregando = true;
        _receitas = await ApiService.ListarReceitasAsync() ?? [];
        _carregando = false;
    }

    private async Task Salvar()
    {
        _erro = string.Empty;

        if (string.IsNullOrWhiteSpace(_descricao) || string.IsNullOrWhiteSpace(_valorStr) || string.IsNullOrWhiteSpace(_dataStr))
        {
            _erro = "Preencha todos os campos obrigatórios.";
            return;
        }

        if (!decimal.TryParse(_valorStr.Replace(",", "."), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var valor) || valor <= 0)
        {
            _erro = "Valor inválido.";
            return;
        }

        if (!DateTime.TryParse(_dataStr, out var data))
        {
            _erro = "Data inválida.";
            return;
        }

        _salvando = true;
        var payload = new
        {
            Descricao = _descricao,
            Valor = valor,
            DataRecebimento = DateOnly.FromDateTime(data),
            Categoria = _categoria,
            Recorrente = _recorrente
        };

        var (sucesso, erro) = await ApiService.CriarReceitaAsync(payload);
        _salvando = false;

        if (sucesso)
        {
            _mostrarForm = false;
            _descricao = string.Empty;
            _valorStr = string.Empty;
            _dataStr = string.Empty;
            _categoria = "Salario";
            _recorrente = false;
            await Carregar();
        }
        else
        {
            _erro = erro ?? "Erro ao salvar receita.";
        }
    }

    private async Task Excluir(Guid id)
    {
        _excluindoId = id;
        await ApiService.ExcluirReceitaAsync(id);
        _excluindoId = null;
        await Carregar();
    }
}
