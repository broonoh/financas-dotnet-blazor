@page "/despesas"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MinhasFinancas.Web.Services
@using MinhasFinancas.Web.Models
@inject DashboardApiService ApiService
@inject IJSRuntime JS

<MudText Typo="Typo.h4" Class="mb-4">Despesas</MudText>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="mb-4" @bind-ActivePanelIndex="_activeTab">

    <!-- ABA: DESPESA FIXA -->
    <MudTabPanel Text="Despesas Fixas">
        <MudPaper Elevation="0" Class="pa-4">
            <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary"
                       Variant="Variant.Filled" OnClick="@(() => { _mostrarFormFixa = !_mostrarFormFixa; _editandoFixaId = null; })" Class="mb-4">
                Nova Despesa Fixa
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Secondary"
                       Variant="Variant.Outlined" OnClick="DownloadFixasPdf" Disabled="_baixandoFixasPdf" Class="mb-4 ml-2">
                @if (_baixandoFixasPdf) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                Exportar PDF
            </MudButton>

            @if (_mostrarFormFixa && _editandoFixaId == null)
            {
                <MudPaper Elevation="1" Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-2">Nova Despesa Fixa</MudText>
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_fixaDescricao" Label="Descrição" Variant="Variant.Outlined" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField @bind-Value="_fixaValorStr" Label="Valor Total (R$)" Variant="Variant.Outlined" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField @bind-Value="_fixaParcelas" Label="Nº de Parcelas" Variant="Variant.Outlined" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudDatePicker @bind-Date="_fixaDataCompra" Label="Data da Compra"
                                           Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" Editable="true" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudDatePicker @bind-Date="_fixaDataPrimeiraParcela" Label="Vencimento 1ª Parcela"
                                           Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" Editable="true" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            @if (_categoriasDespesa?.Count > 0)
                            {
                                <MudSelect T="string" @bind-Value="_fixaCategoria" Label="Categoria" Variant="Variant.Outlined" FullWidth="true">
                                    @foreach (var cat in _categoriasDespesa)
                                    {
                                        <MudSelectItem Value="@cat.Nome">@cat.Nome</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            else
                            {
                                <MudTextField @bind-Value="_fixaCategoria" Label="Categoria" Variant="Variant.Outlined" FullWidth="true"
                                              Placeholder="Nenhuma categoria. Cadastre em Categorias > Despesa" />
                            }
                        </MudItem>
                        <MudItem xs="12" md="5">
                            <MudSelect T="string" @bind-Value="_fixaFormaPagamento" Label="Forma de Pagamento" Variant="Variant.Outlined" FullWidth="true">
                                <MudSelectItem Value="@("CartaoCredito")">Cartão de Crédito</MudSelectItem>
                                <MudSelectItem Value="@("PixParcelado")">Pix Parcelado</MudSelectItem>
                                <MudSelectItem Value="@("BoletoParcelado")">Boleto Parcelado</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12">
                            @if (!string.IsNullOrEmpty(_fixaErro)) { <MudAlert Severity="Severity.Error" Class="mb-2">@_fixaErro</MudAlert> }
                            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SalvarFixa" Disabled="_fixaSalvando">
                                @if (_fixaSalvando) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                Salvar
                            </MudButton>
                            <MudButton Class="ml-2" OnClick="CancelarFixa">Cancelar</MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            }

            @if (_carregandoFixas)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            }
            else if (_despesasFixas?.Count > 0)
            {
                <MudTable Items="_despesasFixas" Hover="true" Striped="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Descrição</MudTh>
                        <MudTh>Valor Total</MudTh>
                        <MudTh>Parcelas</MudTh>
                        <MudTh>1ª Parcela</MudTh>
                        <MudTh>Categoria</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        @if (_editandoFixaId == context.Id)
                        {
                            <MudTd colspan="6">
                                <MudPaper Elevation="0" Class="pa-3">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2">Editando — apenas Descrição, Categoria e Forma de Pagamento</MudText>
                                    <MudGrid>
                                        <MudItem xs="12" md="6">
                                            <MudTextField @bind-Value="_fixaDescricao" Label="Descrição" Variant="Variant.Outlined" FullWidth="true" />
                                        </MudItem>
                                        <MudItem xs="12" md="3">
                                            @if (_categoriasDespesa?.Count > 0)
                                            {
                                                <MudSelect T="string" @bind-Value="_fixaCategoria" Label="Categoria" Variant="Variant.Outlined" FullWidth="true">
                                                    @foreach (var cat in _categoriasDespesa)
                                                    {
                                                        <MudSelectItem Value="@cat.Nome">@cat.Nome</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            }
                                            else
                                            {
                                                <MudTextField @bind-Value="_fixaCategoria" Label="Categoria" Variant="Variant.Outlined" FullWidth="true" />
                                            }
                                        </MudItem>
                                        <MudItem xs="12" md="3">
                                            <MudSelect T="string" @bind-Value="_fixaFormaPagamento" Label="Forma de Pagamento" Variant="Variant.Outlined" FullWidth="true">
                                                <MudSelectItem Value="@("CartaoCredito")">Cartão de Crédito</MudSelectItem>
                                                <MudSelectItem Value="@("PixParcelado")">Pix Parcelado</MudSelectItem>
                                                <MudSelectItem Value="@("BoletoParcelado")">Boleto Parcelado</MudSelectItem>
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="12">
                                            @if (!string.IsNullOrEmpty(_fixaErro)) { <MudAlert Severity="Severity.Error" Class="mb-2">@_fixaErro</MudAlert> }
                                            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="AtualizarFixa" Disabled="_fixaSalvando">
                                                @if (_fixaSalvando) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                                Atualizar
                                            </MudButton>
                                            <MudButton Class="ml-2" OnClick="CancelarFixa">Cancelar</MudButton>
                                        </MudItem>
                                    </MudGrid>
                                </MudPaper>
                            </MudTd>
                        }
                        else
                        {
                            <MudTd>@context.Descricao</MudTd>
                            <MudTd>@context.ValorTotal.ToString("C2", new System.Globalization.CultureInfo("pt-BR"))</MudTd>
                            <MudTd>@context.QuantidadeParcelas x</MudTd>
                            <MudTd>@context.DataPrimeiraParcela.ToString("dd/MM/yyyy")</MudTd>
                            <MudTd>@context.Categoria</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                               OnClick="@(() => IniciarEdicaoFixa(context))" Title="Editar" />
                                @if (_excluindoFixaId == context.Id)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                }
                                else
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                   OnClick="@(() => ExcluirFixa(context.Id))" Title="Excluir" />
                                }
                            </MudTd>
                        }
                    </RowTemplate>
                </MudTable>
            }
            else if (!_carregandoFixas)
            {
                <MudAlert Severity="Severity.Info">Nenhuma despesa fixa cadastrada.</MudAlert>
            }
        </MudPaper>
    </MudTabPanel>

    <!-- ABA: DESPESA EXTRA -->
    <MudTabPanel Text="Despesas Extras">
        <MudPaper Elevation="0" Class="pa-4">
            <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Warning"
                       Variant="Variant.Filled" OnClick="@(() => { _mostrarFormExtra = !_mostrarFormExtra; _editandoExtraId = null; })" Class="mb-4">
                Nova Despesa Extra
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Secondary"
                       Variant="Variant.Outlined" OnClick="DownloadExtrasPdf" Disabled="_baixandoExtrasPdf" Class="mb-4 ml-2">
                @if (_baixandoExtrasPdf) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                Exportar PDF
            </MudButton>

            @if (_mostrarFormExtra && _editandoExtraId == null)
            {
                <MudPaper Elevation="1" Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-2">Nova Despesa Extra</MudText>
                    @FormExtra(false)
                </MudPaper>
            }

            @if (_carregandoExtras)
            {
                <MudProgressLinear Color="Color.Warning" Indeterminate="true" />
            }
            else if (_despesasExtras?.Count > 0)
            {
                <MudTable Items="_despesasExtras" Hover="true" Striped="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Descrição</MudTh>
                        <MudTh>Valor</MudTh>
                        <MudTh>Data</MudTh>
                        <MudTh>Categoria</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        @if (_editandoExtraId == context.Id)
                        {
                            <MudTd colspan="5">
                                <MudPaper Elevation="0" Class="pa-3">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2">Editando despesa extra</MudText>
                                    @FormExtra(true)
                                </MudPaper>
                            </MudTd>
                        }
                        else
                        {
                            <MudTd>@context.Descricao</MudTd>
                            <MudTd>@context.Valor.ToString("C2", new System.Globalization.CultureInfo("pt-BR"))</MudTd>
                            <MudTd>@context.DataDespesa.ToString("dd/MM/yyyy")</MudTd>
                            <MudTd>@context.Categoria</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                               OnClick="@(() => IniciarEdicaoExtra(context))" Title="Editar" />
                                @if (_excluindoExtraId == context.Id)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                }
                                else
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                   OnClick="@(() => ExcluirExtra(context.Id))" Title="Excluir" />
                                }
                            </MudTd>
                        }
                    </RowTemplate>
                </MudTable>
            }
            else if (!_carregandoExtras)
            {
                <MudAlert Severity="Severity.Info">Nenhuma despesa extra cadastrada.</MudAlert>
            }
        </MudPaper>
    </MudTabPanel>

    <!-- ABA: DÍVIDAS -->
    <MudTabPanel Text="Contas a Receber">
        <MudPaper Elevation="0" Class="pa-4">
            <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Error"
                       Variant="Variant.Filled" OnClick="@(() => { _mostrarFormDivida = !_mostrarFormDivida; _editandoDividaId = null; })" Class="mb-4">
                Nova Dívida
            </MudButton>

            @if (_mostrarFormDivida && _editandoDividaId == null)
            {
                <MudPaper Elevation="1" Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-3">Nova Dívida</MudText>
                    <MudGrid>
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="_dividaNomeDevedor" Label="Nome do Devedor" Variant="Variant.Outlined" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="8">
                            <MudTextField @bind-Value="_dividaDescricao" Label="Descrição" Variant="Variant.Outlined" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField @bind-Value="_dividaValorStr" Label="Valor Total (R$)" Variant="Variant.Outlined" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField @bind-Value="_dividaParcelasStr" Label="Nº de Parcelas" Variant="Variant.Outlined" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudDatePicker @bind-Date="_dividaDataCompra" Label="Data da Compra"
                                           Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" Editable="true" />
                        </MudItem>
                        <MudItem xs="12">
                            @if (!string.IsNullOrEmpty(_dividaErro)) { <MudAlert Severity="Severity.Error" Class="mb-2">@_dividaErro</MudAlert> }
                            <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="SalvarDivida" Disabled="_dividaSalvando">
                                @if (_dividaSalvando) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                Registrar Dívida
                            </MudButton>
                            <MudButton Class="ml-2" OnClick="CancelarDivida">Cancelar</MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            }

            @if (_carregandoDividas)
            {
                <MudProgressLinear Color="Color.Error" Indeterminate="true" />
            }
            else if (_dividas?.Count > 0)
            {
                var grupos = _dividas
                    .GroupBy(d => d.NomeDevedor.Trim(), StringComparer.OrdinalIgnoreCase)
                    .OrderBy(g => g.Key)
                    .ToList();

                <MudTabs Elevation="1" Rounded="true" Class="mt-2" ActivePanelIndexChanged="@(_ => { _expandedDividaId = null; })">
                    @foreach (var grupo in grupos)
                    {
                        var pessoa = grupo.Key;
                        var dividasPessoa = grupo.ToList();
                        var totalPessoa = dividasPessoa.Sum(d => d.ValorTotal);
                        var saldoPessoa = dividasPessoa.Sum(d => d.SaldoRestante);
                        var temVencida = dividasPessoa.Any(d => d.Parcelas.Any(p => p.Vencida && !p.Paga));

                        <MudTabPanel>
                            <TabContent>
                                <div class="d-flex align-center gap-1">
                                    <MudText>@pessoa</MudText>
                                    @if (temVencida)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Small" Title="Parcelas vencidas" />
                                    }
                                </div>
                            </TabContent>
                            <ChildContent>
                                <!-- Resumo da pessoa -->
                                <MudPaper Elevation="0" Class="pa-3 mb-3" Style="background: var(--mud-palette-background-grey);">
                                    <div class="d-flex gap-4 align-center">
                                        <div>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Total das dívidas</MudText>
                                            <MudText Typo="Typo.body1"><strong>@totalPessoa.ToString("C2", new System.Globalization.CultureInfo("pt-BR"))</strong></MudText>
                                        </div>
                                        <div>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Saldo restante</MudText>
                                            <MudText Typo="Typo.body1" Color="@(saldoPessoa > 0 ? Color.Error : Color.Success)">
                                                <strong>@saldoPessoa.ToString("C2", new System.Globalization.CultureInfo("pt-BR"))</strong>
                                            </MudText>
                                        </div>
                                        <div>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Dívidas</MudText>
                                            <MudText Typo="Typo.body1"><strong>@dividasPessoa.Count</strong></MudText>
                                        </div>
                                        <MudSpacer />
                                        <MudButton StartIcon="@Icons.Material.Filled.PictureAsPdf"
                                                   Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                                   OnClick="@(() => DownloadPdf(grupo.Key))">
                                            Baixar PDF
                                        </MudButton>
                                    </div>
                                </MudPaper>

                                <!-- Lista de dívidas da pessoa -->
                                @foreach (var divida in dividasPessoa)
                                {
                                    var parcelasTotal = divida.QuantidadeParcelas;
                                    var parcelasPagas = divida.Parcelas.Count(p => p.Paga);
                                    var progressoPercent = parcelasTotal > 0 ? (double)parcelasPagas / parcelasTotal * 100 : 0;
                                    var expanded = _expandedDividaId == divida.Id;

                                    <MudCard Class="mb-3" Elevation="2">
                                        <MudCardHeader>
                                            <CardHeaderContent>
                                                @if (_editandoDividaId == divida.Id)
                                                {
                                                    <MudGrid>
                                                        <MudItem xs="12" md="4">
                                                            <MudTextField @bind-Value="_dividaNomeDevedor" Label="Nome do Devedor" Variant="Variant.Outlined" FullWidth="true" />
                                                        </MudItem>
                                                        <MudItem xs="12" md="8">
                                                            <MudTextField @bind-Value="_dividaDescricao" Label="Descrição" Variant="Variant.Outlined" FullWidth="true" />
                                                        </MudItem>
                                                        <MudItem xs="12">
                                                            @if (!string.IsNullOrEmpty(_dividaErro)) { <MudAlert Severity="Severity.Error" Class="mb-2">@_dividaErro</MudAlert> }
                                                            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="AtualizarDivida" Disabled="_dividaSalvando">
                                                                @if (_dividaSalvando) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                                                                Atualizar
                                                            </MudButton>
                                                            <MudButton Class="ml-2" OnClick="CancelarDivida">Cancelar</MudButton>
                                                        </MudItem>
                                                    </MudGrid>
                                                }
                                                else
                                                {
                                                    <div class="d-flex align-center justify-space-between">
                                                        <div>
                                                            <MudText Typo="Typo.subtitle1"><strong>@divida.Descricao</strong></MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Compra: @divida.DataCompra.ToString("dd/MM/yyyy")</MudText>
                                                        </div>
                                                        <div class="d-flex align-center gap-2">
                                                            <div class="text-right">
                                                                <MudText Typo="Typo.body2">
                                                                    Total: <strong>@divida.ValorTotal.ToString("C2", new System.Globalization.CultureInfo("pt-BR"))</strong>
                                                                </MudText>
                                                                <MudText Typo="Typo.body2" Color="@(divida.SaldoRestante > 0 ? Color.Error : Color.Success)">
                                                                    Saldo: @divida.SaldoRestante.ToString("C2", new System.Globalization.CultureInfo("pt-BR"))
                                                                </MudText>
                                                            </div>
                                                            <MudIconButton Icon="@(expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                                                           OnClick="@(() => ToggleExpand(divida.Id))" />
                                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                                                           OnClick="@(() => IniciarEdicaoDivida(divida))" Title="Editar dívida" />
                                                            @if (_excluindoDividaId == divida.Id)
                                                            {
                                                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                                            }
                                                            else
                                                            {
                                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                                               OnClick="@(() => ExcluirDivida(divida.Id))" Title="Excluir dívida" />
                                                            }
                                                        </div>
                                                    </div>
                                                    <MudProgressLinear Color="Color.Success" Value="@progressoPercent" Class="mt-2" />
                                                    <MudText Typo="Typo.caption">@parcelasPagas / @parcelasTotal parcelas pagas</MudText>
                                                }
                                            </CardHeaderContent>
                                        </MudCardHeader>

                                        @if (expanded && _editandoDividaId != divida.Id)
                                        {
                                            <MudCardContent>
                                                <MudTable Items="@divida.Parcelas" Dense="true" Hover="true">
                                                    <HeaderContent>
                                                        <MudTh>Parcela</MudTh>
                                                        <MudTh>Valor</MudTh>
                                                        <MudTh>Vencimento</MudTh>
                                                        <MudTh>Status</MudTh>
                                                        <MudTh></MudTh>
                                                    </HeaderContent>
                                                    <RowTemplate>
                                                        <MudTd>@context.Numero / @context.TotalParcelas</MudTd>
                                                        <MudTd>@context.Valor.ToString("C2", new System.Globalization.CultureInfo("pt-BR"))</MudTd>
                                                        <MudTd>
                                                            <MudText Color="@(context.Vencida ? Color.Error : Color.Default)">
                                                                @context.DataVencimento.ToString("dd/MM/yyyy")
                                                                @if (context.Vencida) { <span> (vencida)</span> }
                                                            </MudText>
                                                        </MudTd>
                                                        <MudTd>
                                                            @if (context.Paga)
                                                            {
                                                                <MudChip T="string" Color="Color.Success" Size="Size.Small">Paga</MudChip>
                                                            }
                                                            else
                                                            {
                                                                <MudChip T="string" Color="@(context.Vencida ? Color.Error : Color.Default)" Size="Size.Small">Pendente</MudChip>
                                                            }
                                                        </MudTd>
                                                        <MudTd>
                                                            <MudButton Size="Size.Small"
                                                                       Color="@(context.Paga ? Color.Default : Color.Success)"
                                                                       Variant="Variant.Outlined"
                                                                       OnClick="@(() => ToggleParcela(context.Id, !context.Paga, divida.Id))">
                                                                @(context.Paga ? "Desfazer" : "Marcar Paga")
                                                            </MudButton>
                                                        </MudTd>
                                                    </RowTemplate>
                                                </MudTable>
                                            </MudCardContent>
                                        }
                                    </MudCard>
                                }
                            </ChildContent>
                        </MudTabPanel>
                    }
                </MudTabs>
            }
            else if (!_carregandoDividas)
            {
                <MudAlert Severity="Severity.Info">Nenhuma dívida cadastrada.</MudAlert>
            }
        </MudPaper>
    </MudTabPanel>

</MudTabs>

@code {
    private RenderFragment FormExtra(bool editando) =>@<MudGrid>
        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="_extraDescricao" Label="Descrição" Variant="Variant.Outlined" FullWidth="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudTextField @bind-Value="_extraValorStr" Label="Valor (R$)" Variant="Variant.Outlined" FullWidth="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudDatePicker @bind-Date="_extraDataDespesa" Label="Data da Despesa"
                           Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" Editable="true" />
        </MudItem>
        <MudItem xs="12" md="4">
            @if (_categoriasDespesa?.Count > 0)
            {
                <MudSelect T="string" @bind-Value="_extraCategoria" Label="Categoria" Variant="Variant.Outlined" FullWidth="true">
                    @foreach (var cat in _categoriasDespesa)
                    {
                        <MudSelectItem Value="@cat.Nome">@cat.Nome</MudSelectItem>
                    }
                </MudSelect>
            }
            else
            {
                <MudTextField @bind-Value="_extraCategoria" Label="Categoria" Variant="Variant.Outlined" FullWidth="true"
                              Placeholder="Nenhuma categoria. Cadastre em Categorias > Despesa" />
            }
        </MudItem>
        <MudItem xs="12" md="5">
            <MudSelect T="string" @bind-Value="_extraFormaPagamento" Label="Forma de Pagamento" Variant="Variant.Outlined" FullWidth="true">
                <MudSelectItem Value="@("CartaoCredito")">Cartão de Crédito</MudSelectItem>
                <MudSelectItem Value="@("Pix")">Pix</MudSelectItem>
                <MudSelectItem Value="@("Dinheiro")">Dinheiro</MudSelectItem>
                <MudSelectItem Value="@("Boleto")">Boleto</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12">
            @if (!string.IsNullOrEmpty(_extraErro)) { <MudAlert Severity="Severity.Error" Class="mb-2">@_extraErro</MudAlert> }
            <MudButton Color="Color.Warning" Variant="Variant.Filled"
                       OnClick="@(editando ? AtualizarExtra : SalvarExtra)" Disabled="_extraSalvando">
                @if (_extraSalvando) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                @(editando ? "Atualizar" : "Salvar")
            </MudButton>
            <MudButton Class="ml-2" OnClick="CancelarExtra">Cancelar</MudButton>
        </MudItem>
    </MudGrid>;
}

