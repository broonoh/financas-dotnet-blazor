        _fixaCategoria = d.Categoria;
        _fixaFormaPagamento = d.FormaPagamento;
        _fixaErro = string.Empty;
    }

    private void CancelarFixa()
    {
        _mostrarFormFixa = false;
        _editandoFixaId = null;
        _fixaDescricao = string.Empty;
        _fixaValorStr = string.Empty;
        _fixaParcelas = "2";
        _fixaDataCompra = null;
        _fixaDataPrimeiraParcela = null;
        _fixaCategoria = _categoriasDespesa?.FirstOrDefault()?.Nome ?? string.Empty;
        _fixaFormaPagamento = "CartaoCredito";
        _fixaErro = string.Empty;
    }

    private async Task SalvarFixa()
    {
        _fixaErro = string.Empty;

        if (string.IsNullOrWhiteSpace(_fixaDescricao) || string.IsNullOrWhiteSpace(_fixaValorStr) || _fixaDataCompra is null || _fixaDataPrimeiraParcela is null)
        {
            _fixaErro = "Preencha todos os campos obrigatórios.";
            return;
        }
        if (!decimal.TryParse(_fixaValorStr.Replace(",", "."), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var valor) || valor <= 0)
        {
            _fixaErro = "Valor inválido.";
            return;
        }
        if (!int.TryParse(_fixaParcelas, out var parcelas) || parcelas < 2)
        {
            _fixaErro = "Número de parcelas deve ser pelo menos 2.";
            return;
        }

        _fixaSalvando = true;
        var payload = new
        {
            Descricao = _fixaDescricao,
            ValorTotal = valor,
            QuantidadeParcelas = parcelas,
            DataCompra = DateOnly.FromDateTime(_fixaDataCompra!.Value),
            DataPrimeiraParcela = DateOnly.FromDateTime(_fixaDataPrimeiraParcela!.Value),
            Categoria = _fixaCategoria,
            FormaPagamento = _fixaFormaPagamento
        };

        var (sucesso, erro) = await ApiService.CriarDespesaFixaAsync(payload);
        _fixaSalvando = false;

        if (sucesso) { CancelarFixa(); await CarregarFixas(); }
        else _fixaErro = erro ?? "Erro ao salvar despesa.";
    }

    private async Task AtualizarFixa()
    {
        _fixaErro = string.Empty;
        if (string.IsNullOrWhiteSpace(_fixaDescricao))
        {
            _fixaErro = "Descrição é obrigatória.";
            return;
        }

        _fixaSalvando = true;
        var payload = new { Descricao = _fixaDescricao, Categoria = _fixaCategoria, FormaPagamento = _fixaFormaPagamento };
        var (sucesso, erro) = await ApiService.AtualizarDespesaFixaAsync(_editandoFixaId!.Value, payload);
        _fixaSalvando = false;

        if (sucesso) { CancelarFixa(); await CarregarFixas(); }
        else _fixaErro = erro ?? "Erro ao atualizar despesa.";
    }

