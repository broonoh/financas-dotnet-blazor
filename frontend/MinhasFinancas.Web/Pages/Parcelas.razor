@page "/parcelas"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MinhasFinancas.Web.Models
@using MinhasFinancas.Web.Services
@inject DashboardApiService ApiService

<MudText Typo="Typo.h4" Class="mb-4">Minhas Parcelas</MudText>

<!-- Seletor de mês/ano -->
<MudPaper Elevation="1" Class="pa-3 mb-4 d-flex align-center gap-3 flex-wrap">
    <MudText Typo="Typo.body1" Class="mr-2"><strong>Mês de referência:</strong></MudText>
    <MudSelect T="int" Value="_mesSelecionado" ValueChanged="OnMesChanged"
               Label="Mês" Variant="Variant.Outlined" Style="min-width:150px" Dense="true">
        @foreach (var (nome, num) in _meses)
        {
            <MudSelectItem Value="@num">@nome</MudSelectItem>
        }
    </MudSelect>
    <MudSelect T="int" Value="_anoSelecionado" ValueChanged="OnAnoChanged"
               Label="Ano" Variant="Variant.Outlined" Style="min-width:110px" Dense="true">
        @for (int a = DateTime.Now.Year - 1; a <= DateTime.Now.Year + 2; a++)
        {
            var ano = a;
            <MudSelectItem Value="@ano">@ano</MudSelectItem>
        }
    </MudSelect>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Refresh"
               OnClick="Carregar" Disabled="_carregando">
        Atualizar
    </MudButton>
</MudPaper>

@if (_carregando)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else if (!string.IsNullOrEmpty(_erro))
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_erro</MudAlert>
}
else if (_parcelas != null)
{
    var pagas       = _parcelas.Where(p => p.Paga).ToList();
    var vencidas    = _parcelas.Where(p => !p.Paga && p.Vencida).ToList();
    var pendentes   = _parcelas.Where(p => !p.Paga).ToList();

    <!-- Cards de resumo -->
    <MudGrid Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="2" Class="pa-3 text-center" Style="border-top:4px solid var(--mud-palette-primary)">
                <MudText Typo="Typo.h5"><strong>@_parcelas.Count</strong></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Total do mês</MudText>
                <MudText Typo="Typo.body2">@_parcelas.Sum(p => p.Valor).ToString("C2", _ptBR)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="2" Class="pa-3 text-center" Style="border-top:4px solid var(--mud-palette-success)">
                <MudText Typo="Typo.h5" Color="Color.Success"><strong>@pagas.Count</strong></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Pagas</MudText>
                <MudText Typo="Typo.body2" Color="Color.Success">@pagas.Sum(p => p.Valor).ToString("C2", _ptBR)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="2" Class="pa-3 text-center" Style="border-top:4px solid var(--mud-palette-warning)">
                <MudText Typo="Typo.h5" Color="Color.Warning"><strong>@pendentes.Count</strong></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Pendentes</MudText>
                <MudText Typo="Typo.body2" Color="Color.Warning">@pendentes.Sum(p => p.Valor).ToString("C2", _ptBR)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="2" Class="pa-3 text-center" Style="border-top:4px solid var(--mud-palette-error)">
                <MudText Typo="Typo.h5" Color="Color.Error"><strong>@vencidas.Count</strong></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Vencidas</MudText>
                <MudText Typo="Typo.body2" Color="Color.Error">@vencidas.Sum(p => p.Valor).ToString("C2", _ptBR)</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudTabs @bind-ActivePanelIndex="_tabIndex" Elevation="1" Rounded="true" ApplyEffectsToContainer="true">
        <MudTabPanel Text="@($"Todas ({_parcelas.Count})")">
            @TabelaParcelas(_parcelas)
        </MudTabPanel>
        <MudTabPanel Text="@($"Vencidas ({vencidas.Count})")">
            @TabelaParcelas(vencidas)
        </MudTabPanel>
        <MudTabPanel Text="@($"Pendentes ({pendentes.Count})")">
            @TabelaParcelas(pendentes)
        </MudTabPanel>
        <MudTabPanel Text="@($"Pagas ({pagas.Count})")">
            @TabelaParcelas(pagas)
        </MudTabPanel>
    </MudTabs>
}

@code {
    private List<ParcelaDto>? _parcelas;
    private bool _carregando;
    private string _erro = string.Empty;
    private int _mesSelecionado = DateTime.Now.Month;
    private int _anoSelecionado = DateTime.Now.Year;
    private int _tabIndex;

    private static readonly System.Globalization.CultureInfo _ptBR = new("pt-BR");

    private static readonly (string Nome, int Num)[] _meses =
    [
        ("Janeiro", 1), ("Fevereiro", 2), ("Março", 3),
        ("Abril", 4), ("Maio", 5), ("Junho", 6),
        ("Julho", 7), ("Agosto", 8), ("Setembro", 9),
        ("Outubro", 10), ("Novembro", 11), ("Dezembro", 12)
    ];

    protected override async Task OnInitializedAsync() => await Carregar();

    private async Task OnMesChanged(int mes)
    {
        _mesSelecionado = mes;
        await Carregar();
    }

    private async Task OnAnoChanged(int ano)
    {
        _anoSelecionado = ano;
        await Carregar();
    }

    private async Task Carregar()
    {
        _carregando = true;
        _erro = string.Empty;
        StateHasChanged();
        try
        {
            _parcelas = await ApiService.ListarParcelasAsync(_anoSelecionado, _mesSelecionado) ?? [];
        }
        catch (Exception ex)
        {
            _erro = $"Erro ao carregar parcelas: {ex.Message}";
            _parcelas = [];
        }
        _carregando = false;
    }

    private async Task ToggleParcela(ParcelaDto parcela)
    {
        await ApiService.MarcarParcelaPagaAsync(parcela.Id, !parcela.Paga);
        await Carregar();
    }

    private Color GetCorVencimento(ParcelaDto p)
    {
        if (p.Paga) return Color.Success;
        if (p.Vencida) return Color.Error;
        if (p.VenceEm7Dias) return Color.Warning;
        return Color.Default;
    }

    private RenderFragment TabelaParcelas(List<ParcelaDto> lista) =>
    @<div>
        @if (!lista.Any())
        {
            <MudPaper Elevation="0" Class="pa-8 d-flex flex-column align-center" Style="min-height:160px">
                <MudIcon Icon="@Icons.Material.Filled.EventAvailable" Style="font-size:3rem;opacity:.3" Class="mb-3" />
                <MudText Typo="Typo.h6" Style="opacity:.5">Nenhuma parcela nesta categoria</MudText>
                @if (_tabIndex == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                        Não há parcelas com vencimento em @(_meses[_mesSelecionado - 1].Nome)/@_anoSelecionado.
                        Cadastre despesas fixas em <strong>Despesas &gt; Despesas Fixas</strong>.
                    </MudText>
                }
            </MudPaper>
        }
        else
        {
            <MudTable Items="@lista" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Descrição</MudTh>
                    <MudTh>Parcela</MudTh>
                    <MudTh>Valor</MudTh>
                    <MudTh>Vencimento</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Descrição">@context.DescricaoDespesa</MudTd>
                    <MudTd DataLabel="Parcela">@context.Numero / @context.TotalParcelas</MudTd>
                    <MudTd DataLabel="Valor">@context.Valor.ToString("C2", _ptBR)</MudTd>
                    <MudTd DataLabel="Vencimento">
                        <MudText Color="@GetCorVencimento(context)">
                            @context.DataVencimento.ToString("dd/MM/yyyy")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.Paga)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">Paga</MudChip>
                        }
                        else if (context.Vencida)
                        {
                            <MudChip T="string" Color="Color.Error" Size="Size.Small">Vencida</MudChip>
                        }
                        else if (context.VenceEm7Dias)
                        {
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">Vence em breve</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Default" Size="Size.Small">Pendente</MudChip>
                        }
                    </MudTd>
                    <MudTd>
                        <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                   Color="@(context.Paga ? Color.Default : Color.Success)"
                                   OnClick="@(() => ToggleParcela(context))">
                            @(context.Paga ? "Desfazer" : "Marcar Paga")
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </div>;
}
